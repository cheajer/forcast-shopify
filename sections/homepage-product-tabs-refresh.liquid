{{ 'forcast-homepage.css' | asset_url | stylesheet_tag }}
<script src="{{ 'forcast-homepage-tabs.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign new_arrivals = section.settings.new_arrivals_collection
  assign best_sellers = section.settings.best_sellers_collection
  assign new_limit = section.settings.products_to_show
  assign best_limit = section.settings.products_to_show
%}

<section class="forcast-homepage forcast-product-tabs page-width color-{{ section.settings.color_scheme }}" data-forcast-tabs>
  <div class="forcast-section-heading forcast-section-heading--split">
    <div>
      {% if section.settings.eyebrow != blank %}
        <p class="forcast-section-heading__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="forcast-section-heading__title">{{ section.settings.heading }}</h2>
    </div>
    {% if section.settings.intro != blank %}
      <div class="forcast-section-heading__copy rte">{{ section.settings.intro }}</div>
    {% endif %}
  </div>

  <div class="forcast-tabs-nav" role="tablist" aria-label="Product collections">
    <button class="forcast-tab is-active" type="button" role="tab" aria-selected="true" aria-controls="forcast-tab-new-{{ section.id }}" data-tab-trigger="new">New Arrivals</button>
    <button class="forcast-tab" type="button" role="tab" aria-selected="false" aria-controls="forcast-tab-best-{{ section.id }}" data-tab-trigger="best">Best Sellers</button>
  </div>

  <div id="forcast-tab-new-{{ section.id }}" class="forcast-tab-panel is-active" role="tabpanel" data-tab-panel="new">
    <div class="forcast-product-rail" data-auto-scroll>
      {% if new_arrivals != blank and new_arrivals.products_count > 0 %}
        {% for product in new_arrivals.products limit: new_limit %}
          <article class="forcast-product-card">
            <a href="{{ product.url }}" class="forcast-product-card__media">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360,540,720,900', sizes: '(min-width: 1200px) 22vw, (min-width: 750px) 30vw, 72vw', alt: product.featured_image.alt }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </a>
            <div class="forcast-product-card__body">
              <p class="forcast-product-card__vendor">{{ product.vendor | default: shop.name }}</p>
              <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
              <div class="forcast-product-card__price">{{ product.price | money }}</div>
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <article class="forcast-product-card forcast-product-card--placeholder">
            <div class="forcast-product-card__media">{{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <div class="forcast-product-card__body">
              <p class="forcast-product-card__vendor">Forcast</p>
              <h3>New season product {{ i }}</h3>
              <div class="forcast-product-card__price">{{ 12900 | money }}</div>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>

  <div id="forcast-tab-best-{{ section.id }}" class="forcast-tab-panel" role="tabpanel" data-tab-panel="best" hidden>
    <div class="forcast-product-rail" data-auto-scroll>
      {% if best_sellers != blank and best_sellers.products_count > 0 %}
        {% for product in best_sellers.products limit: best_limit %}
          <article class="forcast-product-card">
            <a href="{{ product.url }}" class="forcast-product-card__media">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360,540,720,900', sizes: '(min-width: 1200px) 22vw, (min-width: 750px) 30vw, 72vw', alt: product.featured_image.alt }}
              {% else %}
                {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </a>
            <div class="forcast-product-card__body">
              <p class="forcast-product-card__vendor">{{ product.vendor | default: shop.name }}</p>
              <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
              <div class="forcast-product-card__price">{{ product.price | money }}</div>
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <article class="forcast-product-card forcast-product-card--placeholder">
            <div class="forcast-product-card__media">{{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <div class="forcast-product-card__body">
              <p class="forcast-product-card__vendor">Forcast</p>
              <h3>Best seller {{ i }}</h3>
              <div class="forcast-product-card__price">{{ 14900 | money }}</div>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Homepage product tabs",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Trending now"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover new arrivals and best sellers"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>A clean, editorial carousel inspired by the live Forcast storefront, with swipeable cards on mobile and a gentle auto-scroll effect on larger screens.</p>"
    },
    {
      "type": "collection",
      "id": "new_arrivals_collection",
      "label": "New arrivals collection"
    },
    {
      "type": "collection",
      "id": "best_sellers_collection",
      "label": "Best sellers collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 10,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Homepage product tabs"
    }
  ]
}
{% endschema %}
