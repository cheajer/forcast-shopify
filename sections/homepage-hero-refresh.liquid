          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL",
          "default": "https://cdn.forcast.com.au/media/wysiwyg/OCCASION_DRESSES_4.jpg"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Homepage hero refresh",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Occasion Dresses",
            "copy": "Statement dresses for celebrations, events and evenings out.",
            "image_url": "https://cdn.forcast.com.au/media/wysiwyg/OCCASION_DRESSES_4.jpg"
          }
        },
        {
