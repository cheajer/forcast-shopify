    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "New season arrivals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Women’s fashion clothing and accessories store"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Modern tailoring, occasion dressing and polished essentials designed in Sydney for workdays, weekends and after-dark events.</p>"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop new arrivals"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Explore best sellers"
    },
    {
      "type": "text",
      "id": "desktop_image_url",
      "label": "Desktop image URL",
      "default": "https://cdn.forcast.com.au/media/wysiwyg/25_DRESS_DESKTOP.jpg"
    },
    {
      "type": "text",
      "id": "mobile_image_url",
      "label": "Mobile image URL",
      "default": "https://cdn.forcast.com.au/media/wysiwyg/25_DRESS_MOBILE_1.jpg"
    },
    {
      "type": "text",
      "id": "hero_alt",
      "label": "Hero image alt text",
      "default": "Forcast campaign photography"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Occasion Dresses"
        },
        {
          "type": "text",
