<script>
  (() => {
    const root = document.currentScript.closest('.shopify-section') || document;
    const header = root.querySelector('[data-forcast-header]');
    const toggle = root.querySelector('[data-forcast-mobile-toggle]');
    const panel = root.querySelector('#ForcastMobileMenu');

    const syncHeaderState = () => {
      if (!header) return;
      const panelOpen = panel && !panel.hasAttribute('hidden');
      header.classList.toggle('is-solid', window.scrollY <= 4 || panelOpen);
    };

    if (toggle && panel) {
      toggle.addEventListener('click', () => {
        const isOpen = !panel.hasAttribute('hidden');
        panel.toggleAttribute('hidden', isOpen);
        toggle.setAttribute('aria-expanded', String(!isOpen));
        syncHeaderState();
      });
    }

    syncHeaderState();
    window.addEventListener('scroll', syncHeaderState, { passive: true });
  })();
</script>

{% stylesheet %}
  .forcast-header {
    position: sticky;
    top: 0;
    z-index: var(--layer-sticky);
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .forcast-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgb(var(--color-background-rgb) / 0);
    transition: background-color 180ms ease, opacity 180ms ease;
    z-index: -1;
  }

  .forcast-header.is-solid::before,
  .forcast-header:hover::before,
  .forcast-header:focus-within::before {
    background: rgb(var(--color-background-rgb) / 0.96);
  }

  .forcast-header.is-solid,
  .forcast-header:hover,
  .forcast-header:focus-within {
    border-bottom-color: rgb(var(--color-foreground-rgb) / 0.08);
    box-shadow: 0 1px 0 rgb(var(--color-foreground-rgb) / 0.04);
  }

  .forcast-header__bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
    min-height: 78px;
  }

  .forcast-header__logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .forcast-header__logo img {
    display: block;
    width: 170px;
    max-width: 100%;
    height: auto;
  }

  .forcast-header__nav {
    justify-self: start;
  }

  .forcast-nav {
    display: flex;
    align-items: center;
    gap: 1.8rem;
    margin: 0;
    padding: 0;
  }

  .forcast-nav__item {
    position: relative;
    padding: 1.8rem 0;
  }

  .forcast-nav__link,
  .forcast-header__text-link,
  .forcast-mobile-menu summary,
  .forcast-mobile-menu a {
    text-decoration: none;
    color: rgb(var(--color-foreground-rgb));
    font-size: 1.2rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .forcast-nav__link--sale {
    color: #9a2f44;
  }

  .forcast-header__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.4rem;
  }

  .forcast-header__actions .search-action,
  .forcast-header__actions header-actions {
    margin: 0;
  }

  .forcast-header__actions .header-actions--text {
    gap: 1.4rem;
  }

  .forcast-nav__panel {
    position: absolute;
    left: 0;
    top: 100%;
    display: grid;
    grid-template-columns: repeat(4, minmax(16rem, 1fr));
    gap: 2.4rem;
    min-width: 68rem;
    padding: 2.4rem 2.8rem;
    background: #fff;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    box-shadow: 0 18px 36px rgb(0 0 0 / 0.08);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
  }

  .forcast-nav__panel--simple {
    grid-template-columns: minmax(18rem, 1fr);
    min-width: 24rem;
  }

  .forcast-nav__item--wide .forcast-nav__panel {
    min-width: 82rem;
  }

  .forcast-nav__item:hover .forcast-nav__panel,
  .forcast-nav__item:focus-within .forcast-nav__panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .forcast-nav__column {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .forcast-nav__heading {
    font-size: 1.15rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .forcast-nav__column a {
    color: rgb(var(--color-foreground-rgb));
    text-decoration: none;
    font-size: 1.4rem;
    line-height: 1.45;
  }

  .forcast-header__mobile-toggle,
  .forcast-mobile-menu {
    display: none;
  }

  .forcast-header__icon-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 0;
    background: transparent;
    color: inherit;
  }

  .forcast-mobile-menu {
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    background: #fff;
  }

  .forcast-mobile-menu__inner {
    padding-top: 1.2rem;
    padding-bottom: 1.6rem;
  }

  .forcast-mobile-menu__utility-links,
  .forcast-mobile-menu__submenu {
    display: flex;
    flex-direction: column;
  }

  .forcast-mobile-menu__utility-links {
    gap: 1rem;
    padding-bottom: 1rem;
  }

  .forcast-mobile-menu details {
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    padding: 1.2rem 0;
  }

  .forcast-mobile-menu summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .forcast-mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .forcast-mobile-menu__submenu {
    gap: 0.9rem;
    padding: 1rem 0 0.4rem 0;
  }

  .forcast-mobile-menu__submenu a,
  .forcast-mobile-menu__utility-links a {
    font-size: 1.4rem;
    letter-spacing: 0.04em;
    text-transform: none;
  }

  @media screen and (max-width: 1199px) {
    .forcast-header__bar {
      grid-template-columns: 1fr auto auto;
      gap: 1rem;
      min-height: 64px;
    }

    .forcast-header__mobile-toggle,
    .forcast-mobile-menu {
      display: block;
    }

    .forcast-header__nav,
    .forcast-header__actions .forcast-header__text-link,
    .forcast-header__actions .header-actions--text .account-button__text,
    .forcast-header__actions .header-actions--text .header-actions__cart-icon > span:first-child,
    .forcast-header__actions .search-action--text > button > span:first-child {
      display: none;
    }

    .forcast-header__actions {
      gap: 0.2rem;
    }

    .forcast-header__logo {
      justify-self: center;
    }

    .forcast-header__logo img {
      width: 140px;
    }
  }
{% endstylesheet %}
